---
interface Props {
  eyebrow: string;
  title: string;
}

const { eyebrow, title } = Astro.props;
---

<section class="relative overflow-hidden border-b-[3px] border-ink bg-paper py-16 md:py-20">
  <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
    <div class="reveal reveal-1 mb-5 flex items-center gap-3">
      <span class="sticker">{eyebrow}</span>
      <span class="rule grow"></span>
    </div>
    <h1 class="reveal reveal-2 display-lg riso-shift m-0 max-w-5xl text-ink">{title}</h1>
    <div class="reveal reveal-3 mt-6 max-w-3xl font-body text-xl leading-8 text-muted">
      <slot />
    </div>
  </div>
</section>

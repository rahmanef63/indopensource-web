---
import { Picture } from 'astro:assets';
import { withBase } from '../lib/urls';
import brandIcon from '../assets/brand/icon-192.png';

const navItems = [
  ['Home', '/'],
  ['Falsafah', '/falsafah/'],
  ['Projects', '/projects/'],
  ['Blog', '/blog/'],
  ['Forum', '/forum/'],
  ['Contact', '/contact/']
];

const mobileNavItems = [
  ['Home', '/', 'M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-6H8v6H4a1 1 0 0 1-1-1V10.5Z'],
  ['Projects', '/projects/', 'M4 5a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Zm4 6h8M8 15h5'],
  ['Blog', '/blog/', 'M6 3h9l3 3v15H6V3Zm8 0v4h4M9 11h6M9 15h6'],
  ['Forum', '/forum/', 'M4 5h16v10H8l-4 4V5Zm5 4h6M9 12h4']
];

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPathWithoutBase = currentPath.replace(new RegExp(`^${baseUrl.replace(/\/$/, '')}`), '') || '/';
---

<header class="sticky top-0 z-20 border-b border-ink/10 bg-paper/90 backdrop-blur-xl">
  <nav class="mx-auto flex min-h-17 w-[min(1120px,calc(100%-32px))] items-center justify-between gap-5 py-3 max-sm:flex-col max-sm:items-start" aria-label="Navigasi utama">
    <a class="inline-flex items-center gap-2.5 font-extrabold" href={withBase('/')}>
      <Picture
        src={brandIcon}
        formats={['avif', 'webp']}
        widths={[36, 72]}
        sizes="36px"
        width={36}
        height={36}
        alt=""
        loading="eager"
        class="size-9 rounded-lg object-contain"
      />
      <span>IndopenSource</span>
    </a>
    <div class="flex flex-wrap justify-end gap-1.5 max-md:hidden">
      {
        navItems.map(([label, href]) => (
          <a
            class="rounded-lg px-3 py-2 text-sm font-bold text-muted hover:bg-brand/10 hover:text-brand-dark aria-[current=page]:bg-brand/10 aria-[current=page]:text-brand-dark"
            href={withBase(href)}
            aria-current={currentPathWithoutBase === href ? 'page' : undefined}
          >
            {label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<nav class="fixed inset-x-4 bottom-[calc(env(safe-area-inset-bottom)+3.5rem)] z-30 hidden rounded-2xl border border-line bg-paper/95 p-2 shadow-2xl shadow-ink/20 backdrop-blur-xl max-md:grid max-md:grid-cols-4" aria-label="Navigasi mobile">
  {
    mobileNavItems.map(([label, href, iconPath]) => (
      <a
        class="flex min-h-14 flex-col items-center justify-center gap-1 rounded-xl px-2 py-2 text-center text-xs font-extrabold text-muted hover:bg-brand/10 hover:text-brand-dark aria-[current=page]:bg-brand aria-[current=page]:text-white"
        href={withBase(href)}
        aria-current={currentPathWithoutBase === href ? 'page' : undefined}
      >
        <svg class="size-5" viewBox="0 0 24 24" aria-hidden="true">
          <path d={iconPath} fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
        </svg>
        {label}
      </a>
    ))
  }
</nav>

---
import { Picture } from 'astro:assets';
import { withBase } from '../lib/urls';
import brandIcon from '../assets/brand/icon-192.png';

const navItems = [
  ['Home', '/'],
  ['Falsafah', '/falsafah/'],
  ['Projects', '/projects/'],
  ['Blog', '/blog/'],
  ['Forum', '/forum/'],
  ['Contact', '/contact/']
];

const mobileNavItems = [
  ['Home', '/', 'M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-6H8v6H4a1 1 0 0 1-1-1V10.5Z'],
  ['Projects', '/projects/', 'M4 5a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Zm4 6h8M8 15h5'],
  ['Blog', '/blog/', 'M6 3h9l3 3v15H6V3Zm8 0v4h4M9 11h6M9 15h6'],
  ['Forum', '/forum/', 'M4 5h16v10H8l-4 4V5Zm5 4h6M9 12h4']
];

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPathWithoutBase = currentPath.replace(new RegExp(`^${baseUrl.replace(/\/$/, '')}`), '') || '/';
---

{/*
  EDITORIAL MASTHEAD — riso-zine wordmark stamp, mono nav row, thick ink bottom
  rule. Sticky cream field; the global body grain shows through the translucent
  paper so the bar reads as printed paper, not glass. All depth via design-system
  utilities (.rule, .riso-shadow-sm, .sticker, .meta-row) — no inline styles.
*/}
<header class="sticky top-0 z-20 bg-paper/92 backdrop-blur-md">
  <nav
    class="reveal-stagger mx-auto flex min-h-16 w-[min(1120px,calc(100%-32px))] flex-wrap items-center justify-between gap-x-6 gap-y-3 py-3 max-sm:flex-col max-sm:items-start"
    aria-label="Navigasi utama"
  >
    {/* Wordmark = stamped logo tile + editorial display name + mono kicker */}
    <a
      class="riso-hover group inline-flex items-center gap-3 border-2 border-ink bg-paper px-2.5 py-1.5 riso-shadow-sm"
      href={withBase('/')}
    >
      <Picture
        src={brandIcon}
        formats={['avif', 'webp']}
        widths={[36, 72]}
        sizes="36px"
        width={36}
        height={36}
        alt=""
        loading="eager"
        class="size-9 border border-ink/20 object-contain"
      />
      <span class="flex flex-col leading-none">
        <span class="riso-shift font-display text-xl font-extrabold tracking-tight text-ink">IndopenSource</span>
        <span class="meta-row mt-0.5 text-brand-dark">/ zine open source ID</span>
      </span>
    </a>

    {/* Desktop nav — mono uppercase labels, riso-underline reveal, sticker active state */}
    <div class="flex flex-wrap items-center justify-end gap-x-1 gap-y-2 max-md:hidden">
      {
        navItems.map(([label, href]) => {
          const isCurrent = currentPathWithoutBase === href;
          return isCurrent ? (
            <a
              class="riso-hover inline-flex items-center border-2 border-ink bg-brand px-3 py-1.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white riso-shadow-sm"
              href={withBase(href)}
              aria-current="page"
            >
              {label}
            </a>
          ) : (
            <a
              class="inline-flex items-center border-2 border-transparent px-3 py-1.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-muted transition-colors hover:border-ink hover:bg-sun hover:text-ink"
              href={withBase(href)}
            >
              {label}
            </a>
          );
        })
      }
    </div>
  </nav>
  {/* Signature thick ink bottom rule — the printed edge of the masthead */}
  <hr class="rule" aria-hidden="true" />
</header>

{/*
  MOBILE DOCK — square riso tiles, thick ink border + hard offset shadow, mono
  caps labels, active = brand fill (white text, 7.27:1 AA). No rounded pills.
*/}
<nav
  class="fixed inset-x-3 bottom-[calc(env(safe-area-inset-bottom)+0.75rem)] z-30 hidden border-2 border-ink bg-paper/97 backdrop-blur-md riso-shadow max-md:grid max-md:grid-cols-4"
  aria-label="Navigasi mobile"
>
  {
    mobileNavItems.map(([label, href, iconPath]) => {
      const isCurrent = currentPathWithoutBase === href;
      return (
        <a
          class:list={[
            'flex min-h-14 flex-col items-center justify-center gap-1 px-2 py-2 text-center font-mono text-[0.62rem] font-semibold uppercase tracking-[0.04em] transition-colors',
            isCurrent ? 'bg-brand text-white' : 'text-muted hover:bg-sun hover:text-ink'
          ]}
          href={withBase(href)}
          aria-current={isCurrent ? 'page' : undefined}
        >
          <svg class="size-5" viewBox="0 0 24 24" aria-hidden="true">
            <path d={iconPath} fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          {label}
        </a>
      );
    })
  }
</nav>

---
// RISO-EDITORIAL ambient decoration. Three poster accents — flat spot-ink
// geometry instead of soft ambient lines: halftone dot fields, a 2nd-ink
// "misregistration" offset shape, thick riso strokes, and a stamped concentric
// orbit. The MOTION is on-brand riso, not generic loops: connector rules and the
// orbit ring PRINT-ROLL their dashes (paper pulled past a drum, `riso-roll`),
// the dot screens SHIMMER their ink density (`.motion-screen` -> `riso-shimmer`),
// the stamped satellites JITTER on a sub-pixel off-register wobble (`.motion-pulse`
// -> `riso-jitter`), and the stacked 3-ink frame DRIFTS out of and back into
// register (`.motion-float` -> `riso-misregister`). Purely decorative
// (`aria-hidden`), and every animated element keeps the `.motion-*` class hooks
// so the global reduced-motion catch-all in global.css neutralises it. The public
// API is unchanged (variant + class) so existing call sites in
// index/blog/contact/projects keep working.
//
// `currentColor` drives the halftone fills, so callers tint via a `text-*`
// class (default is the surrounding ink/brand). To break the all-teal monotony
// the geometry now carries VERMILION (--color-accent) and SUN (--color-sun)
// spot inks alongside the teal, so the ambient layer reads as a true multi-ink
// riso pull rather than one flat teal screen. Still decorative + reduced-motion
// safe.
interface Props {
  variant?: 'network' | 'orbit' | 'steps';
  class?: string;
}

const { variant = 'network', class: className = '' } = Astro.props;
---

{
  variant === 'network' && (
    <svg
      class={`pointer-events-none absolute inset-0 h-full w-full text-brand opacity-[0.16] ${className}`}
      viewBox="0 0 900 460"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      {/* Halftone dot field — a printed poster screen that SHIMMERS its ink
          density like a screen catching ink across a pull. */}
      <pattern id="lsm-net-dots" width="22" height="22" patternUnits="userSpaceOnUse">
        <circle cx="3" cy="3" r="2.4" fill="currentColor" />
      </pattern>
      <rect class="motion-screen" x="480" y="-10" width="460" height="300" fill="url(#lsm-net-dots)" />
      {/* A coarser vermilion screen overprints the teal field — a 2nd spot ink
          at a different gauge, so the dot frequency is not uniform. */}
      <pattern id="lsm-net-dots-v" width="40" height="40" patternUnits="userSpaceOnUse">
        <circle cx="5" cy="5" r="3.4" fill="var(--color-accent)" />
      </pattern>
      <rect x="560" y="20" width="380" height="260" fill="url(#lsm-net-dots-v)" opacity="0.5" />
      {/* 3-ink misregistration: teal block, sun offset, vermilion offset. */}
      <rect class="motion-float" x="120" y="250" width="190" height="120" fill="none" stroke="var(--color-accent)" stroke-width="4" />
      <rect x="124" y="254" width="190" height="120" fill="none" stroke="var(--color-sun)" stroke-width="4" />
      <rect x="128" y="258" width="190" height="120" fill="none" stroke="var(--color-brand)" stroke-width="4" />
      {/* Riso connector rule with stamped nodes — mixed spot inks on the nodes. */}
      <path class="motion-line" d="M-20 200 H300 L380 120 H720 L820 200 H940" />
      <g class="motion-dots">
        <circle cx="300" cy="200" r="9" />
        <circle cx="380" cy="120" r="9" fill="var(--color-accent)" />
        <circle cx="720" cy="120" r="9" />
      </g>
    </svg>
  )
}

{
  variant === 'orbit' && (
    <svg
      class={`pointer-events-none absolute right-0 top-6 h-72 w-72 text-brand opacity-[0.18] ${className}`}
      viewBox="0 0 240 240"
      aria-hidden="true"
    >
      {/* Stamped concentric orbit — thick riso strokes, no soft glow. The dot
          screen shimmers its ink density. */}
      <pattern id="lsm-orb-dots" width="14" height="14" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1.6" fill="currentColor" />
      </pattern>
      <circle class="motion-screen" cx="120" cy="120" r="96" fill="url(#lsm-orb-dots)" />
      <circle class="motion-orbit" cx="120" cy="120" r="96" stroke-width="3" />
      {/* Vermilion inner orbit slightly off-register from the teal outer ring. */}
      <circle cx="118" cy="122" r="80" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-dasharray="8 10" />
      <circle cx="120" cy="120" r="62" fill="none" stroke="var(--color-sun)" stroke-width="3" />
      {/* Stamped satellites — one sun (default), one vermilion. */}
      <g class="motion-pulse">
        <rect x="206" y="112" width="16" height="16" />
        <rect x="112" y="16" width="16" height="16" fill="var(--color-accent)" />
      </g>
    </svg>
  )
}

{
  variant === 'steps' && (
    <svg
      class={`pointer-events-none absolute inset-x-0 bottom-0 h-28 w-full text-brand opacity-[0.16] ${className}`}
      viewBox="0 0 900 120"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      {/* Printed step rule with a halftone base band (shimmering ink density)
          and stamped risers. */}
      <pattern id="lsm-step-dots" width="18" height="18" patternUnits="userSpaceOnUse">
        <circle cx="3" cy="3" r="2" fill="currentColor" />
      </pattern>
      <rect class="motion-screen" x="0" y="86" width="900" height="34" fill="url(#lsm-step-dots)" />
      {/* Vermilion riser line offset below the teal step rule — misregistration. */}
      <path d="M0 90 H180 V48 H360 V90 H540 V48 H720 V90 H900" fill="none" stroke="var(--color-accent)" stroke-width="3" opacity="0.55" />
      <path class="motion-line" d="M0 86 H180 V44 H360 V86 H540 V44 H720 V86 H900" stroke-width="4" />
      {/* Stamped step caps — one sun (default), one vermilion. */}
      <g class="motion-pulse">
        <rect x="172" y="36" width="16" height="16" />
        <rect x="532" y="36" width="16" height="16" fill="var(--color-accent)" />
      </g>
    </svg>
  )
}

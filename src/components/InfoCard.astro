---
interface Props {
  status?: string;
  title: string;
}

const { status, title } = Astro.props;
---

<article class="riso-hover riso-shadow flex flex-col border-2 border-ink bg-paper p-5">
  {status && <span class="sticker self-start">{status}</span>}
  <h3 class={`display-sm text-ink ${status ? 'mt-3' : ''}`}>{title}</h3>
  <div class="mt-1 font-body leading-7 text-muted">
    <slot />
  </div>
</article>

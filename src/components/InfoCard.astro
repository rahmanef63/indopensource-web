---
interface Props {
  status?: string;
  title: string;
}

const { status, title } = Astro.props;
---

<article class="rounded-lg border border-line bg-paper p-5">
  {status && <span class="inline-flex rounded-full bg-brand/10 px-2.5 py-1 text-xs font-extrabold text-brand-dark">{status}</span>}
  <h3 class="mt-3 text-lg font-bold">{title}</h3>
  <div class="leading-7 text-muted">
    <slot />
  </div>
</article>

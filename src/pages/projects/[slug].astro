---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BaseButton from '../../components/BaseButton.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import projects from '../../data/projects.json';
import { projectSlug, type Project } from '../../lib/projects';

export function getStaticPaths() {
  return (projects as Project[]).map((project) => ({
    params: { slug: projectSlug(project.fullName) },
    props: { project }
  }));
}

const { project } = Astro.props as { project: Project };
const updatedDate = project.pushedAt || project.updatedAt;
const updatedLabel = updatedDate
  ? new Intl.DateTimeFormat('id-ID', { dateStyle: 'medium' }).format(new Date(updatedDate))
  : '';
const repoName = project.fullName.split('/').at(-1) || project.fullName;
// README is pre-rendered to sanitized HTML at build time (PERF-1); the browser
// no longer fetches GitHub or parses Markdown.
const readmeHtml = project.readmeHtml || '';
// Snippet-clamped description for <meta>/OG, falling back to the raw one (SEO-6).
const metaDescription = project.metaDescription || project.description;
const topics = project.topics ?? [];

// SoftwareSourceCode structured data so search engines understand each project
// page (SEO-4). Passed to BaseLayout's `jsonLd` prop, which emits it in <head>
// and allow-lists its exact hash in the CSP (no separate inline script that a
// strict CSP would drop).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: repoName,
  description: metaDescription,
  codeRepository: project.url,
  ...(project.homepage ? { url: project.homepage } : {}),
  ...(project.language ? { programmingLanguage: project.language } : {}),
  ...(project.owner
    ? { author: { '@type': 'Organization', name: project.owner, ...(project.ownerAvatarUrl ? { image: project.ownerAvatarUrl } : {}) } }
    : {}),
  ...(updatedDate ? { dateModified: updatedDate } : {}),
  ...(typeof project.stars === 'number'
    ? { interactionStatistic: { '@type': 'InteractionCounter', interactionType: 'https://schema.org/LikeAction', userInteractionCount: project.stars } }
    : {})
};
---

<BaseLayout
  title={`${project.fullName} - Project IndopenSource`}
  description={metaDescription}
  image={project.ownerAvatarUrl || undefined}
  type="article"
  jsonLd={jsonLd}
>
  <section class="border-b border-line bg-paper py-14">
    <div class="mx-auto grid w-[min(1040px,calc(100%-40px))] grid-cols-[minmax(0,1fr)_320px] gap-8 max-lg:grid-cols-1">
      <div>
        <p class="mb-3 text-xs font-black uppercase tracking-[0.08em] text-accent">Project detail</p>
        <div class="flex items-start gap-4">
          {project.ownerAvatarUrl && <img class="size-14 rounded-lg border border-line bg-canvas" src={project.ownerAvatarUrl} alt={`Avatar ${project.owner || project.fullName}`} />}
          <div class="min-w-0">
            {project.owner && <p class="mb-2 text-lg font-extrabold text-brand-dark">{project.owner}</p>}
            <h1 class="m-0 text-balance text-[clamp(2.3rem,5vw,4.8rem)] leading-[1.02]">{repoName}</h1>
            <p class="mt-4 max-w-3xl text-lg leading-8 text-muted">{project.description}</p>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-2 text-sm text-muted">
          {project.language && <span class="rounded-full border border-line px-2.5 py-1">{project.language}</span>}
          <span class="rounded-full border border-line px-2.5 py-1">{project.stars.toLocaleString('id-ID')} stars</span>
          <span class="rounded-full border border-line px-2.5 py-1">{project.forks.toLocaleString('id-ID')} forks</span>
          {updatedLabel && <span class="rounded-full border border-line px-2.5 py-1">Update {updatedLabel}</span>}
          {project.latestRelease && <a class="rounded-full border border-line px-2.5 py-1 hover:text-brand" href={project.latestRelease.url}>Latest {project.latestRelease.tagName}</a>}
        </div>
        <div class="mt-7 flex flex-wrap gap-3">
          <BaseButton href={project.url}>Buka GitHub</BaseButton>
          {project.homepage && <BaseButton href={project.homepage} variant="secondary">Homepage</BaseButton>}
          <BaseButton href="/projects/" variant="secondary">Kembali</BaseButton>
        </div>
      </div>
      <ProjectCard project={project} compact />
    </div>
  </section>

  <section class="py-14">
    <div class="mx-auto grid w-[min(1040px,calc(100%-40px))] gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
      <article class="min-w-0 overflow-hidden rounded-lg border border-line bg-paper p-5">
        <div class="mb-5 flex items-center justify-between gap-3">
          <div>
            <p class="mb-2 text-xs font-black uppercase tracking-[0.08em] text-accent">README</p>
            <h2 class="text-2xl font-extrabold">Dokumentasi repo</h2>
          </div>
          <a class="text-sm font-bold text-brand hover:text-brand-dark" href={`${project.url}#readme`}>GitHub</a>
        </div>
        {
          readmeHtml ? (
            <div class="prose-readme max-w-none text-muted" set:html={readmeHtml} />
          ) : (
            <p class="text-muted">
              README belum tersedia di sini. Buka <a class="font-bold text-brand hover:text-brand-dark" href={`${project.url}#readme`}>README langsung dari GitHub</a>.
            </p>
          )
        }
      </article>

      <aside class="grid content-start gap-6">
        <article class="rounded-lg border border-line bg-paper p-5">
          <p class="mb-2 text-xs font-black uppercase tracking-[0.08em] text-accent">Statistik</p>
          <h2 class="text-2xl font-extrabold">Ringkasan repo</h2>
          <dl class="mt-5 grid grid-cols-2 gap-3 text-sm">
            <div class="rounded-lg border border-line bg-canvas p-3">
              <dt class="text-muted">Stars</dt>
              <dd class="text-lg font-extrabold text-brand-dark">{project.stars.toLocaleString('id-ID')}</dd>
            </div>
            <div class="rounded-lg border border-line bg-canvas p-3">
              <dt class="text-muted">Forks</dt>
              <dd class="text-lg font-extrabold text-brand-dark">{project.forks.toLocaleString('id-ID')}</dd>
            </div>
            {project.language && (
              <div class="rounded-lg border border-line bg-canvas p-3">
                <dt class="text-muted">Bahasa</dt>
                <dd class="text-base font-extrabold text-brand-dark">{project.language}</dd>
              </div>
            )}
            {updatedLabel && (
              <div class="rounded-lg border border-line bg-canvas p-3">
                <dt class="text-muted">Update</dt>
                <dd class="text-base font-extrabold text-brand-dark">{updatedLabel}</dd>
              </div>
            )}
          </dl>
        </article>
        {
          topics.length > 0 && (
            <article class="rounded-lg border border-line bg-paper p-5">
              <p class="mb-2 text-xs font-black uppercase tracking-[0.08em] text-accent">Tags</p>
              <div class="flex flex-wrap gap-2 text-sm font-bold text-brand-dark">
                {topics.map((topic) => <span class="rounded-full bg-brand/10 px-2.5 py-1">#{topic}</span>)}
              </div>
            </article>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>

---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const {
  title = 'IndopenSource',
  description = 'Roadmap website IndopenSource untuk proyek open source Indonesia.',
  image = '/brand/indopensource-logo.png',
  type = 'website'
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const canonicalUrl = new URL(Astro.url.pathname.replace(baseUrl, '/'), Astro.site || 'https://indopensource.org').toString();
const imageUrl = new URL(image, Astro.site || 'https://indopensource.org').toString();
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f6f5c" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${baseUrl}brand/favicon.ico`} sizes="any" />
    <link rel="icon" href={`${baseUrl}brand/favicon-32.png`} type="image/png" />
    <link rel="apple-touch-icon" href={`${baseUrl}brand/apple-touch-icon.png`} />
    <meta property="og:site_name" content="IndopenSource" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
